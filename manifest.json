{
    "manifest_version": 3,
    "name": "ChatGPT Bulk Unarchive",
    "version": "1.0.1",
    "description": "Automatically unarchive all ChatGPT archived chats",
    "permissions": [
        "scripting",
        "activeTab"
    ],
    "host_permissions": [
        "https://chatgpt.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "ChatGPT Bulk Unarchive"
    },
    "background": {
        "service_worker": "background.js"
    }
}